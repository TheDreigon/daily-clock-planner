{
  "name": "daily-clock-planner",
  "version": "1.0.0",
  "description": "Daily schedule visualization with analog clock",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win && node create-shortcut.js",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "author": "TheDreigon",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.0.5"
  },
  "build": {
    "appId": "com.dailyclockplanner.app",
    "productName": "Daily Clock Planner",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  }
}